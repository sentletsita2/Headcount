generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  lecturer
  student
}

enum AttendanceStatus {
  present
  absent
  late
}

model Department {
  id           String               @id @default(cuid())
  name         String               @unique
  users        User[]
  courses      Course[]
  programmes   ProgrammeDepartment[]
}

model Programme {
  id          String               @id @default(cuid())
  name        String               @unique
  // ✅ No longer has a single departmentId — uses join table instead
  departments ProgrammeDepartment[]
  students    User[]
}

// ✅ Join table: programme ↔ department (many-to-many)
model ProgrammeDepartment {
  programmeId  String
  departmentId String
  programme    Programme  @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([programmeId, departmentId])
  @@unique([programmeId, departmentId])
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         Role
  studentId    String?  @unique
  staffId      String?  @unique
  phone        String?
  yearOfStudy  Int?

  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  programmeId    String?
  programme      Programme?  @relation(fields: [programmeId], references: [id])

  enrolledCourses  StudentCourse[]
  assignedCourses  LecturerCourse[]
  attendance       AttendanceRecord[] @relation("StudentAttendance")
  markedAttendance AttendanceRecord[] @relation("MarkedByAttendance")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id            String   @id @default(cuid())
  name          String
  code          String   @unique
  description   String?
  year          Int?
  credits       Int?
  maxEnrollment Int?

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  enrolledStudents  StudentCourse[]
  assignedLecturers LecturerCourse[]
  attendance        AttendanceRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentCourse {
  studentId  String
  courseId   String
  student    User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@id([studentId, courseId])
}

model LecturerCourse {
  lecturerId String
  courseId   String
  lecturer   User   @relation(fields: [lecturerId], references: [id], onDelete: Cascade)
  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([lecturerId, courseId])
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  date      DateTime
  status    AttendanceStatus

  courseId  String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  studentId String
  student   User   @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)

  markedById String
  markedBy   User   @relation("MarkedByAttendance", fields: [markedById], references: [id])

  createdAt DateTime @default(now())
}
model ActivityLog {
  id              String   @id @default(cuid())
  category        String   // 'auth' | 'user_management' | 'attendance' | 'student_status' | 'data_export'
  action          String
  detail          String   @db.Text
  severity        String   @default("info") // 'info' | 'warning' | 'error'
  performedBy     String
  performedByName String
  timestamp       DateTime @default(now())

  @@index([category])
  @@index([severity])
  @@index([timestamp])
  @@index([performedBy])
}
